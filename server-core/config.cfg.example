HOST=127.0.0.1
PORT=4100
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT (beliebigen langen zufälligen String wählen!)
JWT_SECRET=DEIN_GEHEIMER_JWT_KEY_HIER
TOKEN_TTL_HOURS=24

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=buenzlifight
DB_USER=root
DB_PASSWORD=DEIN_DB_PASSWORT
DB_CONNECTION_LIMIT=10
MIGRATIONS_DIR=./sql

# Buenzli Event System
BUENZLI_EVENTS_ENABLED=true

# Discord Bot Webhook
DISCORD_BOT_WEBHOOK_URL=http://127.0.0.1:4200/event

# Google OAuth 2.0 (aus Google Cloud Console)
GOOGLE_CLIENT_ID=DEINE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=DEIN_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://deine-domain.ch/api/auth/google/callback
FRONTEND_URL=https://deine-domain.ch
